# Exclude common Wolfram/Mathematica file types from GitHub language statistics
# These flags tell GitHub Linguist to treat them as vendored (ignored)
*.nb linguist-vendored=true
*.wl linguist-vendored=true
*.wls linguist-vendored=true

# If you prefer to treat them as documentation instead, use:
# *.nb linguist-documentation=true*.png filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.anim filter=lfs diff=lfs merge=lfs -text